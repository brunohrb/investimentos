         document.addEventListener('DOMContentLoaded', function() {
             console.log('Portal PRB carregado com sucesso!');
+
+            // ── PWA: Service Worker ──
+            if ('serviceWorker' in navigator) {
+                navigator.serviceWorker.register('sw.js').then(r => {
+                    console.log('SW registrado:', r.scope);
+                }).catch(e => console.warn('SW erro:', e));
+            }
+
+            // ── PWA: Apple Touch Icon (iOS exige PNG) ──
+            const canvas = document.createElement('canvas');
+            canvas.width = 180; canvas.height = 180;
+            const ctx = canvas.getContext('2d');
+
+            // Fundo azul arredondado
+            const grad = ctx.createLinearGradient(0, 0, 180, 180);
+            grad.addColorStop(0, '#1e40af');
+            grad.addColorStop(1, '#0f172a');
+            ctx.fillStyle = grad;
+            ctx.beginPath();
+            ctx.roundRect(0, 0, 180, 180, 36);
+            ctx.fill();
+
+            // Retângulo dourado sutil
+            const gradGold = ctx.createLinearGradient(0, 0, 180, 180);
+            gradGold.addColorStop(0, 'rgba(212,175,55,0.15)');
+            gradGold.addColorStop(1, 'rgba(244,208,63,0.15)');
+            ctx.fillStyle = gradGold;
+            ctx.beginPath();
+            ctx.roundRect(28, 46, 124, 88, 14);
+            ctx.fill();
+
+            // Texto "PRB"
+            const gradText = ctx.createLinearGradient(0, 0, 180, 0);
+            gradText.addColorStop(0, '#d4af37');
+            gradText.addColorStop(1, '#f4d03f');
+            ctx.fillStyle = gradText;
+            ctx.font = '800 58px "Segoe UI","Helvetica Neue",Arial,sans-serif';
+            ctx.textAlign = 'center';
+            ctx.textBaseline = 'middle';
+            ctx.fillText('PRB', 90, 90);
+
+            // Texto "HOLDING"
+            ctx.fillStyle = '#93c5fd';
+            ctx.font = '600 15px "Segoe UI","Helvetica Neue",Arial,sans-serif';
+            ctx.letterSpacing = '3px';
+            ctx.fillText('HOLDING', 90, 125);
+
+            const link = document.createElement('link');
+            link.rel = 'apple-touch-icon';
+            link.href = canvas.toDataURL('image/png');
+            document.head.appendChild(link);
         });
     </script>
